generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Transaction {
  id            String                @id @default(cuid())
  userId        String?
  amount        Float
  date          DateTime
  description   String
  category      String
  type          String
  source        String                @default("manual")
  recurringId   String?
  recurring     RecurringTransaction? @relation(fields: [recurringId], references: [id])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model RecurringTransaction {
  id           String        @id @default(cuid())
  userId       String?
  amount       Float
  description  String
  category     String
  type         String
  source       String        @default("manual")
  dayOfMonth   Int
  startDate    DateTime?
  active       Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model MonthlyLimit {
  id         String   @id @default(cuid())
  userId     String?
  category   String
  limitValue Float
  month      Int
  year       Int
  updatedAt  DateTime @updatedAt

  @@unique([userId, category, month, year])
}

model Caixinha {
  id                  String            @id @default(cuid())
  userId              String
  name                String
  description         String
  targetValue         Float
  monthlyContribution Float
  checkIns            CaixinhaCheckIn[]
  extras              CaixinhaExtra[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model CaixinhaCheckIn {
  id         String   @id @default(cuid())
  caixinhaId String
  caixinha   Caixinha @relation(fields: [caixinhaId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  createdAt  DateTime @default(now())

  @@unique([caixinhaId, month, year])
}

model CaixinhaExtra {
  id         String   @id @default(cuid())
  caixinhaId String
  caixinha   Caixinha @relation(fields: [caixinhaId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  amount     Float
  createdAt  DateTime @default(now())
}
